---
import Search from "astro-pagefind/components/Search";
---

<div class="search-container">
  <button id="search-btn" aria-label="Search" class="search-button">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
  </button>
  
  <dialog id="search-dialog" class="search-dialog">
    <div class="search-dialog-inner">
      <div class="search-header">
        <form method="dialog">
          <button class="close-btn" aria-label="Close search">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </form>
      </div>
      <div class="search-content">
        <Search id="search" className="pagefind-ui" uiOptions={{ showImages: false }} />
      </div>
    </div>
  </dialog>
</div>

<script>
  /* global document, setTimeout */
  const btn = document.getElementById('search-btn');
  const dialog = document.getElementById('search-dialog');

  btn?.addEventListener('click', () => {
    // @ts-ignore
    dialog?.showModal();
    // モーダルを開いた時にPagefindの入力項目にフォーカスを当てる
    setTimeout(() => {
      const input = dialog?.querySelector('.pagefind-ui__search-input');
      // @ts-ignore
      input?.focus();
    }, 100);
  });

  // バックドロップのクリックで閉じる処理
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) {
      // @ts-ignore
      dialog.close();
    }
  });
</script>

<style>
  .search-container {
    display: flex;
    align-items: center;
  }
  .search-button {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--black);
    padding: 0.5em;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .search-button:hover {
    color: var(--accent);
  }
  .search-button svg {
    width: 20px;
    height: 20px;
  }
  
  .search-dialog {
    padding: 0;
    border: none;
    border-radius: 8px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    width: 100%;
    max-width: 600px;
    backdrop-filter: blur(5px);
  }
  
  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(3px);
  }
  
  .search-dialog-inner {
    display: flex;
    flex-direction: column;
    max-height: 80vh;
  }
  
  .search-header {
    display: flex;
    justify-content: flex-end;
    padding: 10px;
    border-bottom: 1px solid #eee;
  }
  
  .close-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #666;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }
  
  .close-btn:hover {
    background-color: #f5f5f5;
  }
  
  .search-content {
    padding: 20px;
    overflow-y: auto;
  }
</style>

<style is:global>
  /* Pagefind UI のカスタマイズ */
  .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--black);
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #eeeeee;
    --pagefind-ui-tag: #eeeeee;
    --pagefind-ui-border-width: 2px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: inherit;
  }
  
  .pagefind-ui .pagefind-ui__search-input {
    font-weight: normal;
  }
</style>
